# Server Configuration
PORT=3000
NODE_ENV=production

# Session
SESSION_SECRET=change-this-to-a-random-string

# Admin User (change password after first login)
ADMIN_PASSWORD=admin123

# Database
DB_DIR=./data

# MiniMax API Key (encrypted format: enc:aes-256-gcm-encrypted-data)
# Or plain text (not recommended for production)
# MINIMAX_API_KEY=your-api-key-here
ENCRYPTED_MINIMAX_KEY=enc:your-encrypted-api-key-here

# MiniMax API URL (default: https://api.minimax.chat)
MINIMAX_API_URL=https://api.minimax.chat

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3001

# Master Key for encryption (must be 32+ characters)
MASTER_KEY=change-this-to-a-secure-master-key