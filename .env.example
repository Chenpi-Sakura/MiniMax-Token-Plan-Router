# MiniMax Proxy Configuration

# Session secret (change in production!)
SESSION_SECRET=change-this-to-a-random-string-at-least-32-chars

# Admin user password (change after first login!)
ADMIN_PASSWORD=admin123

# MiniMax API Key (encrypted format recommended)
# Get your API key from: https://platform.minimaxi.com/user-center/basic-information/interface-key
# For production, use encrypted format: enc:YOUR_ENCRYPTED_KEY
# For development/testing, you can use plain text (NOT RECOMMENDED)
MINIMAX_API_KEY=your-minimax-api-key-here

# Encryption key for storing MiniMax API key (must be 32+ characters)
# Generate with: openssl rand -hex 32
MASTER_KEY=change-this-to-a-secure-master-key-at-least-32-characters

# MiniMax API endpoint
MINIMAX_API_URL=https://api.minimax.chat

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3001